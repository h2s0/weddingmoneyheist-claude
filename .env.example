# VITE_ 변수는 브라우저 번들에 포함될 수 있습니다. 공개 가능한 값만 사용하세요.
VITE_API_BASE_URL=http://localhost:3000
VITE_APP_ENV=development

# 아래 변수는 Node backend 전용입니다. 절대로 VITE_ 접두사를 붙이지 마세요.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes
BETTER_AUTH_URL=http://localhost:3000
KAKAO_CLIENT_ID=replace-with-kakao-rest-api-key
KAKAO_CLIENT_SECRET=replace-with-kakao-client-secret
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 증권사 자격증명 원문은 환경변수나 DB에 직접 저장하지 않습니다.
# backend가 KMS로 암호화할 때 사용할 키 식별자만 설정합니다.
BROKER_KMS_KEY_ID=replace-with-kms-key-id
